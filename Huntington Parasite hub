local SECTIONS = {}

function registerSection(name, func, order)
    table.insert(SECTIONS, {
        name = name,
        func = func,
        order = order or #SECTIONS + 1
    })
    table.sort(SECTIONS, function(a, b) return a.order < b.order end)
end

function rebuildSidebar()
    Sidebar:ClearAllChildren()
    
    for _, section in ipairs(SECTIONS) do
        local btn = Instance.new("TextButton", Sidebar)
        btn.Size = UDim2.new(1, 0, 0, CONFIG.sizes.button_height)
        btn.Text = section.name
        btn.BackgroundColor3 = CONFIG.colors.button_default
        btn.TextColor3 = CONFIG.colors.text
        btn.Font = Enum.Font.Roboto
        btn.TextScaled = true
        btn.LayoutOrder = section.order
        
        btn.MouseButton1Click:Connect(function()
            print("[UI] Opening section: "..section.name)
            section.func()
        end)
    end
end

