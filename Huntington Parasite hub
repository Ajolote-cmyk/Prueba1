local function applyHighlightWithName(target, customName, customColor)
    if not target or not target.Parent then return end
    
    task.wait(0.1)
    
    local highlightColor = customColor or colorsByModel[target.Name] or Color3.fromRGB(255,255,255)
    local displayName = customName or target.Name
    
    local existingHl = target:FindFirstChildOfClass("Highlight")
    if existingHl then existingHl:Destroy() end
    
    local hl = Instance.new("Highlight")
    hl.FillColor = highlightColor
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.FillTransparency = 0.3
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = target
    
    local primaryPart = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso") or target:FindFirstChild("Head")
    if primaryPart then
        local hl2 = Instance.new("Highlight")
        hl2.FillColor = highlightColor
        hl2.OutlineColor = Color3.fromRGB(255,255,255)
        hl2.FillTransparency = 0.3
        hl2.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl2.Parent = primaryPart
    end
    
    local existingTag = target:FindFirstChild("NameTag")
    if existingTag then existingTag:Destroy() end
    
    local attachment = primaryPart or target:FindFirstChildWhichIsA("BasePart")
    if attachment then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "NameTag"
        billboard.Size = UDim2.new(0,130,0,20)
        billboard.StudsOffset = Vector3.new(0,3,0)
        billboard.AlwaysOnTop = true
        billboard.Parent = attachment
        
        local nameLabel = Instance.new("TextLabel", billboard)
        nameLabel.Size = UDim2.new(1,0,1,0)
        nameLabel.BackgroundTransparency = 0.5
        nameLabel.BackgroundColor3 = Color3.fromRGB(0,0,0)
        nameLabel.Text = displayName
        nameLabel.TextColor3 = highlightColor
        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)
        nameLabel.Font = Enum.Font.Roboto
        nameLabel.TextSize = 14
    end
end

local function removeHighlight(target)
    if not target then return end
    
    local hl = target:FindFirstChildOfClass("Highlight")
    if hl then hl:Destroy() end
    
    for _, part in ipairs(target:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("Model") then
            local partHl = part:FindFirstChildOfClass("Highlight")
            if partHl then partHl:Destroy() end
            
            local nameTag = part:FindFirstChild("NameTag")
            if nameTag then nameTag:Destroy() end
        end
    end
    
    local nameTag = target:FindFirstChild("NameTag")
    if nameTag then nameTag:Destroy() end
end

local function updateAllHighlights()
    print("[Highlights] Actualizando highlights")
    
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("Model") then
            removeHighlight(child)
        end
    end
    
    for _, child in ipairs(workspace:GetChildren()) do
        if not child:IsA("Model") then continue end
        
        if highlights.npc and table.find(infectedModelNames, child.Name) then
            applyHighlightWithName(child)
        end
        
        if child:FindFirstChild("Humanoid") then
            local playerName = "Unknown"
            local playerObj = nil
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr.Character == child then
                    playerName = plr.Name
                    playerObj = plr
                    break
                end
            end
            
            if highlights.puppet and hasPuppetTrue(child) then
                local displayName = getPuppetDisplayName(child, playerName)
                applyHighlightWithName(child, displayName, COLORS.PUPPET)
            elseif highlights.infected and playerObj and playerObj.Team and playerObj.Team.Name == "Infected" then
                local infectionType = getInfectionType(child)
                local displayText = "INFECTED: "..playerName
                if infectionType and infectionType ~= "" then
                    displayText = displayText.." ["..infectionType.."]"
                end
                applyHighlightWithName(child, displayText, COLORS.INFECTED)
            end
        end
    end
end

-- ============================
-- SISTEMA DE APUNTADO CON PREDICCIÓN
-- ============================

local targetingEnabled = false
local currentTarget = nil
local targetHighlight = nil
local targetConnection = nil
local camera = workspace.CurrentCamera
local aimSmoothness = 0.15 -- Un poco más rápido para mejor respuesta

-- Variables para predicción
local lastTargetPosition = nil
local lastTargetTime = nil
local targetVelocity = Vector3.new(0,0,0)

local parasiteModels = {
    "Infant", "Mature", "Puppeteer", "Injector", "Beacon",
    "Explosive", "Broodling", "Broodlord", "Flyer", "Tendril"
}

local MAX_TARGET_DISTANCE = 100
local SHOOT_DAMAGE = 25
local PREDICTION_FACTOR = 0.5 -- Factor de predicción (0 = sin predicción, 1 = predicción completa)

-- Obtener la HEAD del modelo
local function getTargetHead(target)
    if not target then return nil end
    
    local head = target:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head
    end
    
    for _, child in ipairs(target:GetDescendants()) do
        if child.Name == "Head" and child:IsA("BasePart") then
            return child
        end
    end
    
    return nil
end

-- Calcular velocidad del objetivo
local function updateTargetVelocity(target)
    if not target then 
        targetVelocity = Vector3.new(0,0,0)
        return
    end
    
    local head = getTargetHead(target)
    if not head then 
        targetVelocity = Vector3.new(0,0,0)
        return
    end
    
    local currentPos = head.Position
    local currentTime = tick()
    
    if lastTargetPosition and lastTargetTime then
        local dt = currentTime - lastTargetTime
        if dt > 0 then
            targetVelocity = (currentPos - lastTargetPosition) / dt
        end
    end
    
    lastTargetPosition = currentPos
    lastTargetTime = currentTime
end

-- Predecir posición futura de la HEAD
local function getPredictedHeadPosition(target)
    if not target then return nil end
    
    local head = getTargetHead(target)
    if not head then return nil end
    
    -- Usar velocidad para predecir posición futura
    local predictionTime = 0.1 -- Predecir 0.1 segundos en el futuro
    local predictedPos = head.Position + targetVelocity * predictionTime * PREDICTION_FACTOR
    
    return predictedPos
end

-- Encontrar el parásito más cercano
local function findClosestParasite()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local playerPos = player.Character.HumanoidRootPart.Position
    local closestDistance = MAX_TARGET_DISTANCE
    local closestParasite = nil
    
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("Model") and table.find(parasiteModels, child.Name) then
            local head = getTargetHead(child)
            if head then
                local distance = (playerPos - head.Position).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestParasite = child
                end
            end
        end
    end
    
    return closestParasite
end

-- Apuntar a la posición predicha de la HEAD
local function aimAtPredictedHead(target)
    if not target or not camera then return end
    
    -- Actualizar velocidad del objetivo
    updateTargetVelocity(target)
    
    -- Obtener posición predicha
    local predictedPos = getPredictedHeadPosition(target)
    if not predictedPos then return end
    
    local cameraPos = camera.CFrame.Position
    local desiredCFrame = CFrame.lookAt(cameraPos, predictedPos)
    
    camera.CFrame = camera.CFrame:Lerp(desiredCFrame, aimSmoothness)
end

-- Disparar al objetivo
local function shootCurrentTarget()
    if not currentTarget then 
        print("[Target] No hay objetivo")
        return false 
    end
    
    local humanoid = currentTarget:FindFirstChild("Humanoid")
    if not humanoid then
        humanoid = currentTarget:FindFirstChildWhichIsA("Humanoid")
    end
    
    if humanoid then
        local newHealth = humanoid.Health - SHOOT_DAMAGE
        if newHealth <= 0 then
            humanoid.Health = 0
            print("[Disparo] Parásito eliminado: "..currentTarget.Name)
            
            if targetingEnabled then
                currentTarget = nil
                if targetHighlight then
                    targetHighlight:Destroy()
                    targetHighlight = nil
                end
            end
        else
            humanoid.Health = newHealth
            print("[Disparo] Daño aplicado a "..currentTarget.Name..": "..SHOOT_DAMAGE.." puntos")
            
            -- Efecto visual en la posición predicha
            local head = getTargetHead(currentTarget)
            if head then
                local impactPart = Instance.new("Part")
                impactPart.Size = Vector3.new(1, 1, 1)
                impactPart.Position = head.Position
                impactPart.Anchored = true
                impactPart.CanCollide = false
                impactPart.Transparency = 0.5
                impactPart.BrickColor = BrickColor.new("Bright red")
                impactPart.Parent = workspace
                
                game:GetService("Debris"):AddItem(impactPart, 0.2)
            end
        end
        return true
    end
    return false
end

-- Actualizar highlight
local function updateTargetHighlight()
    if targetHighlight then
        targetHighlight:Destroy()
        targetHighlight = nil
    end
    
    if currentTarget then
        targetHighlight = Instance.new("Highlight")
        targetHighlight.FillColor = CONFIG.colors.target_color
        targetHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        targetHighlight.FillTransparency = 0.2
        targetHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        targetHighlight.Parent = currentTarget
    end
end

-- Loop principal
local function targetingLoop()
    while targetingEnabled do
        local newTarget = findClosestParasite()
        
        if newTarget ~= currentTarget then
            currentTarget = newTarget
            updateTargetHighlight()
            
            if currentTarget then
                print("[Target] Nuevo objetivo: "..currentTarget.Name)
                -- Resetear velocidad al cambiar de objetivo
                targetVelocity = Vector3.new(0,0,0)
                lastTargetPosition = nil
            end
        end
        
        if currentTarget then
            aimAtPredictedHead(currentTarget)
        end
        
        task.wait(0.03)
    end
    
    currentTarget = nil
    if targetHighlight then
        targetHighlight:Destroy()
        targetHighlight = nil
    end
end

-- Activar/Desactivar
local function setTargetingEnabled(enabled)
    if enabled == targetingEnabled then return end
    
    targetingEnabled = enabled
    
    if targetingEnabled then
        print("[Target] Sistema de apuntado ACTIVADO (con predicción)")
        
        task.spawn(targetingLoop)
        
        targetConnection = game:GetService("UserInputService").InputBegan:Connect(function(input)
            if targetingEnabled and input.UserInputType == Enum.UserInputType.MouseButton1 then
                shootCurrentTarget()
            end
        end)
    else
        print("[Target] Sistema de apuntado DESACTIVADO")
        if targetConnection then
            targetConnection:Disconnect()
            targetConnection = nil
        end
    end
end

