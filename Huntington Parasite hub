local boundaries = { xmin = -21, xmax = 35, zmin = 30, zmax = 86 }

-- ============================
-- FUNCIONES DE TELETRANSPORTE
-- ============================

local function insideSquare(pos)
    return pos.X >= boundaries.xmin and pos.X <= boundaries.xmax
       and pos.Z >= boundaries.zmin and pos.Z <= boundaries.zmax
end

local function randomPositionInside()
    local basePos = Vector3.new(8,6,59)
    local offsetX = math.random(-5,5)
    local offsetZ = math.random(-5,5)
    return basePos + Vector3.new(offsetX,0,offsetZ)
end

local function startLoop(character)
    local hrp = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")

    while scriptActive and humanoid.Parent do
        local pos = hrp.Position
        if not insideSquare(pos) then
            hrp.CFrame = CFrame.new(randomPositionInside())
        end
        task.wait(1)
    end
end

