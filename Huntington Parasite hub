local function getMyInfectionType()
    if player.Character then
        local infectionValue = player.Character:FindFirstChild("InfectionType")
        if infectionValue then
            if infectionValue:IsA("StringValue") then
                return infectionValue.Value
            elseif infectionValue:IsA("BoolValue") then
                return infectionValue.Value and "true" or "false"
            elseif infectionValue:IsA("NumberValue") then
                return tostring(infectionValue.Value)
            end
        end
    end
    return nil
end

-- ============================
-- FUNCIONES DE MUERTE
-- ============================

local function killPlayer(humanoid)
    if not humanoid or not humanoid.Parent then return false end
    
    local success = false
    
    pcall(function()
        humanoid.Health = 0
        success = true
    end)
    
    if not success or humanoid.Health > 0 then
        task.wait(0.5)
        pcall(function()
            humanoid.Health = 0
            success = true
        end)
    end
    
    if not success or humanoid.Health > 0 then
        pcall(function()
            if player.Character then
                player.Character:BreakJoints()
                success = true
            end
        end)
    end
    
    return success
end

local function killAfterDelay(character)
    if deathActive then
        deathCancelled = true
        deathActive = false
        deathThread = nil
    end
    
    deathCancelled = false
    deathActive = true
    
    local infectionType = getMyInfectionType()
    if infectionType == "Puppeteer" then
        print("[Sistema] Muerte cancelada - Infectado por Puppeteer")
        deathActive = false
        return
    end
    
    print("[Sistema] Secuencia de muerte iniciada - Morirás en 2 segundos")
    
    task.spawn(function()
        for i = 1, 2 do
            if deathCancelled or not deathActive then
                print("[Sistema] Muerte cancelada")
                deathActive = false
                return
            end
            
            local currentInfection = getMyInfectionType()
            if currentInfection == "Puppeteer" then
                print("[Sistema] Muerte cancelada - Te convertiste en Puppeteer")
                deathActive = false
                return
            end
            
            task.wait(1)
        end
        
        if deathCancelled or not deathActive then 
            deathActive = false
            return 
        end
        
        local finalInfection = getMyInfectionType()
        if finalInfection == "Puppeteer" then
            print("[Sistema] Muerte cancelada - Puppeteer detectado")
            deathActive = false
            return
        end
        
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            local humanoid = player.Character.Humanoid
            local success = killPlayer(humanoid)
            
            if success then
                print("[Sistema] Jugador eliminado")
            else
                print("[Sistema] Error al eliminar jugador")
            end
        end
        
        deathActive = false
        deathThread = nil
    end)
end

local function cancelDeath()
    if deathActive then
        deathCancelled = true
        deathActive = false
        deathThread = nil
        print("[Sistema] Muerte cancelada manualmente")
        return true
    else
        print("[Sistema] No hay secuencia de muerte activa")
        return false
    end
end

local function watchInfectionType()
    if player.Character then
        local infectionValue = player.Character:FindFirstChild("InfectionType")
        if infectionValue then
            infectionValue.Changed:Connect(function()
                local newValue = getMyInfectionType()
                if newValue == "Puppeteer" then
                    cancelDeath()
                end
            end)
        end
        
        player.Character.ChildAdded:Connect(function(child)
            if child.Name == "InfectionType" then
                task.wait(0.1)
                if getMyInfectionType() == "Puppeteer" then
                    cancelDeath()
                end
                
                child.Changed:Connect(function()
                    if getMyInfectionType() == "Puppeteer" then
                        cancelDeath()
                    end
                end)
            end
        end)
    end
end

-- ============================
-- FUNCIONES DE PUPPET
-- ============================

local function hasPunch(character)
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower() == "punch" then
            return true
        end
    end
    return false
end

local function hasSlash(character)
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower() == "slash" then
            return true
        end
    end
    return false
end

local function getPuppetLevel(character)
    if not character then return 0 end
    
    local level = 0
    
    local puppetValue = character:FindFirstChild("Puppet")
    if puppetValue and puppetValue:IsA("BoolValue") and puppetValue.Value == true then
        level = 1
    else
        return 0
    end
    
    local evolutionModel = character:FindFirstChild("PuppetEvolution1")
    if evolutionModel and evolutionModel:IsA("Model") then
        if evolutionModel:FindFirstChild("TorsoSetter") then
            level = 2
        else
            for _, descendant in ipairs(evolutionModel:GetDescendants()) do
                if descendant.Name == "TorsoSetter" then
                    level = 2
                    break
                end
            end
        end
    end
    
    if level >= 2 then
        if hasPunch(character) then
            level = 3
        end
    end
    
    if level >= 3 then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid and humanoid.WalkSpeed >= 18 then
            level = 4
        end
    end
    
    return level
end

local function getPuppetDisplayName(character, playerName)
    local level = getPuppetLevel(character)
    if level > 0 then
        return "PUPPET Lv."..level..": "..playerName
    else
        return "PUPPET: "..playerName
    end
end

